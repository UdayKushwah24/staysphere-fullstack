                    </div>
                </div>
                <div class="w-px h-8 bg-gray-300 hidden md:block"></div>
                <div class="flex-1 w-full flex justify-between items-center text-left pl-6 pr-2 py-2 hover:bg-gray-100 rounded-full cursor-pointer transition">
                    <div>
                        <div class="text-xs font-bold text-gray-800">Who</div>
                        <div class="text-sm text-gray-400">Add guests</div>
                    </div>
                    <button class="bg-brand hover:bg-brandDark text-white w-12 h-12 rounded-full flex items-center justify-center transition-colors shadow-lg ml-4">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </button>
                </div>
            </div>
        </div>
    </header>

